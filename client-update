    --Ballcrack-accent-color: linear-gradient(270deg, #3b82f6, #8b5cf6, #3b82f6);
    --button-color: transparent;
    --hover-color: rgba(59, 130, 246, 0.15);
    --panel-bg: rgba(11, 15, 25, 0.9);
    --header-bg: rgba(7, 10, 18, 0.95);
    --text-color: #e2e8f0;
    --header-text-size: 16px;
    --button-text-size: 14px;
    --setting-text-size: 13px;
    --border-radius: 8px;
    --element-radius: 6px;
    --shadow-color: rgba(0, 0, 0, 0.6);
