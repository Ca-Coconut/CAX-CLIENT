@keyframes flowingLiquid {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

.gui-panel {
    position: fixed;
    z-index: 1000;
    width: 225px;
    border-radius: var(--border-radius);
    background-color: var(--panel-bg);
    border: 1px solid rgba(59, 130, 246, 0.2);
    box-shadow: 0 4px 20px rgba(0,0,0,0.6), 0 0 10px rgba(59, 130, 246, 0.1);
    backdrop-filter: blur(var(--blur-intensity));
    -webkit-backdrop-filter: blur(var(--blur-intensity));
    color: var(--text-color);
    overflow: hidden;
    transform-style: preserve-3d;
    will-change: transform, opacity;
    user-select: none;
}

.with-animations .gui-panel.dragging {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    transform: scale(1.02);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.8);
}

.gui-header {
    background-color: var(--header-bg);
    height: 45px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--header-text-size);
    color: var(--Ballcrack-accent-color-1);
    letter-spacing: 0.5px;
    cursor: grab;
    border-bottom: 1px solid rgba(59, 130, 246, 0.2);
}

.gui-header:active {
    cursor: grabbing;
}

.gui-button-container {
    padding: 0;
    background: transparent;
}

.gui-button {
    height: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: var(--button-text-size);
    font-weight: 400;
    background: var(--button-color);
    color: var(--text-color);
    transition: all 0.2s var(--standard-easing);
    border-bottom: 1px solid rgba(59, 130, 246, 0.1);
}

.gui-button:last-child {
    border-bottom: none;
}

.gui-button:hover:not(.enabled) {
    background: var(--hover-color);
    color: #fff;
}

.gui-button.enabled {
    background: linear-gradient(90deg, rgba(59, 130, 246, 0.2), rgba(139, 92, 246, 0.05));
    color: #3b82f6;
    font-weight: 500;
    border-left: 2px solid #3b82f6;
}

.gui-setting-container {
    padding: 10px 12px;
    background: rgba(0, 0, 0, 0.25);
    border-bottom: 1px solid rgba(59, 130, 246, 0.1);
}

.gui-setting-container .gui-setting-label {
    font-size: var(--setting-text-size);
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 6px;
}

.setting-boolean {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px;
    cursor: pointer;
}

.setting-boolean .gui-setting-label {
    margin-bottom: 0;
}

.gui-checkbox {
    width: 36px;
    height: 18px;
    border-radius: 9px;
    background: rgba(0, 0, 0, 0.6);
    position: relative;
    transition: all 0.2s ease;
}

.gui-checkbox::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #888;
    transition: all 0.2s ease;
}

.gui-checkbox.enabled {
    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
}

.gui-checkbox.enabled::after {
    transform: translateX(18px);
    background: #ffffff;
}

.gui-text-input {
    width: 100%;
    height: 28px;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: var(--element-radius);
    color: #fff;
    padding: 0 10px;
    font-size: 13px;
    transition: all 0.2s ease;
}

.gui-text-input:focus {
    border-color: #3b82f6;
    outline: none;
    box-shadow: 0 0 8px rgba(59, 130, 246, 0.3);
}

.gui-dropdown {
    height: 28px;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: var(--element-radius);
    padding: 0 10px;
}

.gui-dropdown-options {
    background: rgba(11, 15, 25, 0.95);
    backdrop-filter: blur(10px);
    border-radius: var(--element-radius);
    border: 1px solid rgba(59, 130, 246, 0.3);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.8);
    animation: dropdown-appear 300ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.gui-dropdown-option {
    padding: 10px 12px;
    font-size: 13px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.02);
}

.gui-dropdown-option:hover {
    background: rgba(59, 130, 246, 0.15);
}

.gui-dropdown-option.selected {
    color: #60a5fa;
    background: rgba(59, 130, 246, 0.2);
}

.module-settings-wrapper {
    max-height: 0;
    opacity: 0;
    visibility: hidden;
    overflow: hidden;
    margin-top: 0;
    background-color: rgba(7, 10, 18, 0.95);
    border-radius: 0 0 5px 5px;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    border-left: 2px solid transparent;
}

.module-settings-wrapper.module-settings-open {
    max-height: 500px;
    opacity: 1;
    visibility: visible;
    border-left: 2px solid #3b82f6;
}

.module-settings {
    max-height: 300px;
    overflow-y: auto;
    overflow-x: hidden;
}

.gui-color-picker {
    border-radius: var(--element-radius);
    border: 1px solid rgba(59, 130, 246, 0.2);
}

.scrollable-container::-webkit-scrollbar {
    width: 3px;
}
.scrollable-container::-webkit-scrollbar-thumb {
    background: rgba(59, 130, 246, 0.3);
    border-radius: 10px;
}

@keyframes dropdown-appear {
    from {
        opacity: 0;
        transform: translateY(-5px) scaleY(0.95);
    }
    to {
        opacity: 1;
        transform: translateY(0) scaleY(1);
    }
}

/* CAX NOTIFICATION SYSTEM CSS */
.cax-notification {
    background: rgba(11, 15, 25, 0.95);
    border-radius: 6px;
    padding: 8px 10px;
    display: flex;
    align-items: center;
    gap: 12px;
    width: 200px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.6), 0 0 10px rgba(59, 130, 246, 0.1);
    backdrop-filter: blur(10px);
    transform: translateX(120%);
    opacity: 0;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    font-family: 'Inter', sans-serif;
    overflow: hidden;
    max-height: 60px;
    border: 1px solid rgba(59, 130, 246, 0.3);
}

.cax-notification.show {
    transform: translateX(0);
    opacity: 1;
    max-height: 60px;
}

.cax-notif-icon {
    width: 34px;
    height: 34px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: inset 0 0 5px rgba(0,0,0,0.2);
}

.cax-notif-switch {
    width: 14px;
    height: 2px;
    background: #fff;
    position: relative;
}

.cax-notif-switch::after {
    content: '';
    position: absolute;
    width: 6px;
    height: 6px;
    background: #fff;
    border-radius: 50%;
    top: -2px;
    transition: all 0.2s ease;
}

.cax-notif-switch.on::after { right: -2px; }
.cax-notif-switch.off::after { left: -2px; }

.cax-notif-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.cax-notif-title {
    color: #fff;
    font-weight: 700;
    font-size: 14px;
    line-height: 1.1;
}

.cax-notif-name {
    color: rgba(255, 255, 255, 0.6);
    font-size: 13px;
    margin-top: 3px;
    line-height: 1.1;
}
